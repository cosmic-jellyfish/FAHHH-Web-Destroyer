{
    "manifest_version": 3,
    "name": "Faahh Boom",
    "version": "2.1.0",
    "description": "FAAHH sound, screen shake, and page chunks gone until reload. Use responsibly (don't).",
    "permissions": ["activeTab", "storage", "contextMenus"],
    "background": {
      "service_worker": "background.js"
    },
    "icons": {
      "16": "fahh-logo.png",
      "32": "fahh-logo.png",
      "48": "fahh-logo.png",
      "128": "fahh-logo.png"
    },
    "action": {
      "default_title": "FAAHH — click for feelings",
      "default_popup": "popup.html",
      "default_icon": {
        "16": "fahh-logo.png",
        "32": "fahh-logo.png",
        "48": "fahh-logo.png",
        "128": "fahh-logo.png"
      }
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["styles.css"],
        "run_at": "document_idle"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["fahhh.mp3"],
        "matches": ["<all_urls>"]
      }
    ]
  }